  file_change {
    absolute_path_uri: "file:///src/adapters/huggingface.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { ChatCompletionRequest, ExecuteTierFunction, ChatMessage } from \'../types.js\';\n\n/**\n * Builds a prompt for Mistral using the HuggingFace text generation format.\n * Embeds the system prompt cleanly into the first user message.\n */\nfunction buildMistralPrompt(messages: ChatMessage[]): string {\n  let prompt = \'<s>\';\n  let hasSystem = false;\n  let systemContent = \'\';\n  \n  for (const msg of messages) {\n    if (msg.role === \'system\') {\n      systemContent = msg.content;\n      hasSystem = true;\n    } else if (msg.role === \'user\') {\n      const content = hasSystem ? `${systemContent}\\n\\n${msg.content}` : msg.content;\n      prompt += `[INST] ${content} [/INST] `;\n      hasSystem = false; // System prompt is now consumed\n    } else if (msg.role === \'assistant\') {\n      prompt += `${msg.content}</s> `;\n    }\n  }\n  return prompt;\n}\n\n/**\n * Creates a TransformStream to parse HuggingFace SSE tokens and map them to OpenAI chunks.\n */\nfunction createHFTransformStream(modelId: string) {\n  let buffer = \'\';\n\n  return new TransformStream({\n    transform(chunk, controller) {\n      buffer += new TextDecoder().decode(chunk, { stream: true });\n      const lines = buffer.split(\'\\n\');\n      buffer = lines.pop() || \'\'; // keep the incomplete line in the buffer\n\n      for (const line of lines) {\n        if (!line.trim() || !line.startsWith(\'data:\')) continue;\n        const dataStr = line.replace(/^data:\\s*/, \'\').trim();\n        \n        if (dataStr === \'[DONE]\') {\n          controller.enqueue(new TextEncoder().encode(\'data: [DONE]\\n\\n\'));\n          continue;\n        }\n\n        try {\n          const hfChunk = JSON.parse(dataStr);\n          const tokenText = hfChunk.token?.text || \'\';\n          const isDone = hfChunk.token?.special || false;\n\n          if (tokenText || isDone) {\n            const openAIChunk = {\n              id: `chatcmpl-${Date.now()}`,\n              object: \'chat.completion.chunk\',\n              created: Math.floor(Date.now() / 1000),\n              model: modelId,\n              choices: [\n                {\n                  index: 0,\n                  delta: {\n                    content: tokenText,\n                  },\n                  finish_reason: isDone ? \'stop\' : null,\n                }\n              ]\n            };\n            controller.enqueue(new TextEncoder().encode(`data: ${JSON.stringify(openAIChunk)}\\n\\n`));\n          }\n        } catch (err) {\n          // Incomplete chunk or parse error - ignore and continue reading\n        }\n      }\n    },\n    flush(controller) {\n      // Stream is finished\n    }\n  });\n}\n\n/**\n * HuggingFace Tier Adapter\n * \n * Interacts with HuggingFace Serverless Inference API.\n * Maps OpenAI request to native text-generation request format, and maps responses back.\n */\nexport const executeHuggingFace: ExecuteTierFunction = async (req, signal) => {\n  const apiKey = process.env.HF_API_KEY;\n  if (!apiKey) {\n    throw new Error(\'HF_API_KEY is not set\');\n  }\n\n  const modelId = process.env.HF_MODEL_ID || \'mistralai/Mistral-7B-Instruct-v0.2\';\n  const hfUrl = `https://api-inference.huggingface.co/models/${modelId}`;\n\n  const prompt = buildMistralPrompt(req.messages);\n\n  const payload = {\n    inputs: prompt,\n    parameters: {\n      max_new_tokens: req.max_tokens || 1024,\n      temperature: req.temperature ?? 0.7,\n      return_full_text: false,\n    },\n    stream: req.stream || false,\n  };\n\n  const response = await fetch(hfUrl, {\n    method: \'POST\',\n    headers: {\n      \'Content-Type\': \'application/json\',\n      \'Authorization\': `Bearer ${apiKey}`,\n    },\n    body: JSON.stringify(payload),\n    signal,\n  });\n\n  if (!response.ok) {\n    throw new Error(`HuggingFace HTTP error: ${response.status} - ${response.statusText}`);\n  }\n\n  // Handle non-streaming response format mapping\n  if (!req.stream) {\n    const data = await response.json();\n    let generatedText = \'\';\n    \n    if (Array.isArray(data) && data.length > 0 && data[0].generated_text !== undefined) {\n      generatedText = data[0].generated_text;\n    } else if (data.generated_text !== undefined) {\n      generatedText = data.generated_text;\n    }\n\n    const openAIResponse = {\n      id: `chatcmpl-${Date.now()}`,\n      object: \'chat.completion\',\n      created: Math.floor(Date.now() / 1000),\n      model: modelId,\n      choices: [\n        {\n          index: 0,\n          message: {\n            role: \'assistant\',\n            content: generatedText,\n          },\n          finish_reason: \'stop\',\n        },\n      ],\n    };\n\n    return new Response(JSON.stringify(openAIResponse), {\n      status: 200,\n      headers: { \'Content-Type\': \'application/json\' },\n    });\n  }\n\n  // Streaming branch: pipe the original response through our translator stream\n  const transformStream = createHFTransformStream(modelId);\n  const stream = response.body?.pipeThrough(transformStream);\n\n  return new Response(stream, {\n    status: 200,\n    headers: {\n      \'Content-Type\': \'text/event-stream\',\n      \'Cache-Control\': \'no-cache\',\n      \'Connection\': \'keep-alive\',\n    },\n  });\n};\n"
    }
