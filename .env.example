# Proxy Server Configuration

# Tier 1 - Groq Cloud (Blazing Fast Free Tier)
GROQ_API_KEY=""
# Single model (Llama 3.3 70B is popular for speed)
# GROQ_MODELS="llama-3.3-70b-versatile"
# Multiple models (comma-separated list for round-robin load balancing)
GROQ_MODELS="llama-3.3-70b-versatile,llama-3.1-8b-instant,qwen/qwen3.6-27b"

# Tier 2 - OpenRouter
OPENROUTER_API_KEY=""
# Single model
# OPENROUTER_MODELS="meta-llama/llama-3-8b-instruct"
# Multiple models (comma-separated list for round-robin load balancing)
OPENROUTER_MODELS="meta-llama/llama-3-8b-instruct"

# Tier 2
HF_API_KEY=""
# HF_MODEL_ID="mistralai/Mistral-7B-Instruct-v0.2"

# Tier 3
GEMINI_API_KEY=""

# Tier 4 (Fallback)
FALLBACK_API_KEY=""
FALLBACK_BASE_URL="https://api.openai.com"
FALLBACK_MODEL="gpt-3.5-turbo"

# Config
TIER_TIMEOUT_MS="15000"

# HF Image Config
# HF_IMAGE_MODEL_ID="black-forest-labs/FLUX.1-schnell"

# Fallback Image Config
FALLBACK_IMAGE_API_KEY=""
FALLBACK_IMAGE_BASE_URL="https://api.openai.com"
FALLBACK_IMAGE_MODEL="dall-e-3"

